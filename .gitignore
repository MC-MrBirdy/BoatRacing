# Strict allowlist: ignore everything by default
/*

# Keep the ignore file itself
!.gitignore

# Allow essential project files
!/pom.xml
!/README.md
!/LICENSE

# Allow source code
!/src/**

# Explicitly allow source/resource parent directories so nested new files are visible to Git
!/src/
!/src/main/
!/src/main/java/
!/src/main/java/**
!/src/main/resources/
!/src/main/resources/**
!/src/main/resources/messages_*.yml

# Ignore Maven wrapper (incl. properties)

# Allow GitHub meta if present
!/.github/
!/.github/**
!/.github/ISSUE_TEMPLATE/
!/.github/ISSUE_TEMPLATE/**

# Explicit excludes (redundant with the allowlist but documented)
/mvnw
/mvnw.cmd
/target/
/dependency-reduced-pom.xml
/.classpath
/.project
/.settings/
/.vscode/
/.project
/.factorypath
/.mvn/
 
# Allow QA checklist to be committed
!/CHECKLIST.md

